# Public — safe to expose to the browser. Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: the service_role key is NOT here. It never touches the client.
# It belongs only to the edge functions / cron jobs that import results and
# run scoring (steps 6 & 8), set as a secret on those functions.
